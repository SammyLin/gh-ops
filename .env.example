# GitHub OAuth App 設定
# 請到 https://github.com/settings/developers 建立 OAuth App

# OAuth App Client ID
GITHUB_CLIENT_ID=your_client_id

# OAuth App Client Secret
GITHUB_CLIENT_SECRET=your_client_secret

# Session 加密密鑰（請用 openssl rand -hex 32 產生）
SESSION_SECRET=your_session_secret

# 可選：Server 監聽 port（預設 9091）
# PORT=9091

# 可選：Base URL（用於 OAuth callback）
# BASE_URL=http://localhost:9091

# 可選：Audit DB 路徑（預設 ./audit.db）
# AUDIT_DB_PATH=./audit.db
